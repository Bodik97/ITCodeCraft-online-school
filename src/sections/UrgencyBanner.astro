---
import content from "../data/data.json";
---

<div id="urgency-banner" class="bg-gradient-to-r from-neon-magenta via-purple-600 to-neon-orange text-ink relative z-[60]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 flex items-center justify-between gap-4">
    <div class="flex items-center gap-3 flex-1 justify-center sm:justify-start">
      <div class="flex items-center gap-1.5 animate-pulse">
        <span class="text-base">🔥</span>
        <span class="font-bold text-sm uppercase tracking-wider">{content.urgencyBanner.attentionLabel}</span>
      </div>

      <div class="flex items-center gap-3 text-sm font-medium">
        <span class="hidden sm:inline">{content.urgencyBanner.messagePrefix}</span>
        <span>
          {content.urgencyBanner.remainingLabel}
          <span class="font-bold text-lg mx-1">{content.urgencyBanner.remainingSpots}</span>
          / {content.urgencyBanner.totalSpots}
        </span>
      </div>

      <div class="hidden md:block w-32 h-2 bg-black/20 rounded-full overflow-hidden">
        <div class="h-full bg-white rounded-full shadow-[0_0_10px_rgba(255,255,255,0.5)]" style={`width: ${content.urgencyBanner.progressPercent}%`}></div>
      </div>
    </div>

    <button
      type="button"
      data-close-urgency
      aria-label={content.urgencyBanner.closeLabel}
      class="text-ink/80 hover:text-ink transition-colors p-1 hover:bg-white/70 rounded"
    >
      ✕
    </button>
  </div>
</div>
