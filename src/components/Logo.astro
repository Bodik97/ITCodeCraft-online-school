---
import content from "../data/data.json";

interface Props {
  size?: "md" | "sm";
  href?: string;
  className?: string;
}

const { size = "md", href = "https://itcodecraft.tech/", className = "" } = Astro.props;
const isSmall = size === "sm";
const brandPrimary = content.brand.primary ?? "ITCode";
const brandAccent = content.brand.accent ?? "Craft";
const brandPrefix = brandPrimary.startsWith("IT") ? "IT" : brandPrimary.slice(0, 2);
const brandBase = brandPrimary.slice(brandPrefix.length);
---

<a
  href={href}
  aria-label={`${brandPrimary}${brandAccent}`}
  class:list={["ic-logo group", isSmall ? "ic-logo--sm" : "ic-logo--md", className]}
>

  <span class="ic-wordmark">
    <span class="ic-name">
      <span class="ic-name-prefix">{brandPrefix}</span><span class="ic-name-base">{brandBase}</span><span
        class="ic-name-accent">{brandAccent}</span
      >
    </span>
    <span class="ic-subline">IT SCHOOL · ONLINE</span>
  </span>
</a>

<style>
  .ic-logo {
    --ic-cyan: var(--color-neon-cyan, #22d3ee);
    --ic-lime: var(--color-neon-lime, #84cc16);
    --ic-text: var(--color-ink, #e6eef9);
    --ic-muted: rgba(230, 238, 249, 0.5);
    --ic-mark-size: 64px;
    --ic-ring-mid-size: 48px;
    --ic-square-size: 28px;
    --ic-dot-size: 7px;
    --ic-name-size: 26px;
    --ic-sub-size: 8px;
    --ic-gap: 14px;

    display: inline-flex;
    align-items: center;
    gap: var(--ic-gap);
    text-decoration: none;
    position: relative;
    z-index: 2;
  }

  .ic-logo--sm {
    --ic-mark-size: 54px;
    --ic-ring-mid-size: 40px;
    --ic-square-size: 24px;
    --ic-dot-size: 6px;
    --ic-name-size: 22px;
    --ic-sub-size: 7px;
    --ic-gap: 12px;
  }

  .ic-mark {
    position: relative;
    width: var(--ic-mark-size);
    height: var(--ic-mark-size);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ic-ring-outer {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 1.5px solid rgba(34, 211, 238, 0.24);
    animation: ic-spin-slow 12s linear infinite;
  }

  .ic-ring-outer::before {
    content: "";
    position: absolute;
    width: calc(var(--ic-mark-size) * 0.11);
    height: calc(var(--ic-mark-size) * 0.11);
    border-radius: 50%;
    background: var(--ic-cyan);
    box-shadow: 0 0 10px rgba(34, 211, 238, 0.7);
    top: calc(var(--ic-mark-size) * -0.055);
    left: 50%;
    transform: translateX(-50%);
  }

  .ic-ring-mid {
    position: absolute;
    width: var(--ic-ring-mid-size);
    height: var(--ic-ring-mid-size);
    border-radius: 50%;
    border: 1px solid rgba(34, 211, 238, 0.12);
    border-top-color: rgba(34, 211, 238, 0.58);
    animation: ic-spin-slow 7s linear infinite reverse;
  }

  .ic-inner-square {
    position: absolute;
    width: var(--ic-square-size);
    height: var(--ic-square-size);
    transform: rotate(45deg);
    border: 1.5px solid rgba(34, 211, 238, 0.52);
    background: rgba(34, 211, 238, 0.08);
  }

  .ic-inner-square::before,
  .ic-inner-square::after {
    content: "";
    position: absolute;
    width: calc(var(--ic-square-size) * 0.25);
    height: calc(var(--ic-square-size) * 0.25);
    border-color: var(--ic-lime);
    border-style: solid;
  }

  .ic-inner-square::before {
    top: -1px;
    left: -1px;
    border-width: 1.5px 0 0 1.5px;
  }

  .ic-inner-square::after {
    right: -1px;
    bottom: -1px;
    border-width: 0 1.5px 1.5px 0;
  }

  .ic-core-dot {
    width: var(--ic-dot-size);
    height: var(--ic-dot-size);
    border-radius: 50%;
    background: var(--ic-lime);
    position: relative;
    z-index: 2;
    box-shadow:
      0 0 0 2px rgba(132, 204, 22, 0.18),
      0 0 10px rgba(132, 204, 22, 0.82),
      0 0 20px rgba(132, 204, 22, 0.45);
    animation: ic-core-pulse 2s ease-in-out infinite;
  }

  .ic-crosshair {
    position: absolute;
    inset: 0;
  }

  .ic-ch-line {
    position: absolute;
    background: rgba(34, 211, 238, 0.35);
  }

  .ic-ch-top,
  .ic-ch-bottom {
    width: 1px;
    height: calc(var(--ic-mark-size) * 0.18);
    left: 50%;
    transform: translateX(-50%);
  }

  .ic-ch-top {
    top: 0;
  }

  .ic-ch-bottom {
    bottom: 0;
  }

  .ic-ch-left,
  .ic-ch-right {
    height: 1px;
    width: calc(var(--ic-mark-size) * 0.18);
    top: 50%;
    transform: translateY(-50%);
  }

  .ic-ch-left {
    left: 0;
  }

  .ic-ch-right {
    right: 0;
  }

  .ic-wordmark {
    display: inline-flex;
    flex-direction: column;
    line-height: 1;
    gap: 5px;
  }

  .ic-name {
    font-family: "Outfit", "Inter", sans-serif;
    font-size: var(--ic-name-size);
    font-weight: 900;
    letter-spacing: -0.04em;
    white-space: nowrap;
  }

  .ic-name-prefix {
    color: var(--ic-cyan);
    text-shadow: 0 0 18px rgba(34, 211, 238, 0.45);
  }

  .ic-name-base {
    color: var(--ic-text);
  }

  .ic-name-accent {
    color: rgba(255, 255, 255, 0.35);
    font-weight: 300;
    letter-spacing: -0.03em;
  }

  .ic-subline {
    font-family: "DM Mono", "Space Mono", monospace;
    font-size: var(--ic-sub-size);
    letter-spacing: 0.28em;
    color: var(--ic-muted);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .ic-logo--sm .ic-subline {
    display: none;
  }

  .ic-logo:hover .ic-name-prefix,
  .ic-logo:focus-visible .ic-name-prefix {
    color: #67e8f9;
  }

  .ic-logo:hover .ic-ring-outer,
  .ic-logo:focus-visible .ic-ring-outer {
    border-color: rgba(34, 211, 238, 0.42);
  }

  .ic-logo:hover .ic-core-dot,
  .ic-logo:focus-visible .ic-core-dot {
    box-shadow:
      0 0 0 2px rgba(132, 204, 22, 0.22),
      0 0 14px rgba(132, 204, 22, 0.88),
      0 0 26px rgba(132, 204, 22, 0.52);
  }

  @keyframes ic-spin-slow {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes ic-core-pulse {
    0%,
    100% {
      transform: scale(1);
    }

    50% {
      transform: scale(1.24);
    }
  }

  @media (max-width: 768px) {
    .ic-logo--md {
      --ic-mark-size: 58px;
      --ic-ring-mid-size: 44px;
      --ic-square-size: 26px;
      --ic-dot-size: 6px;
      --ic-name-size: 24px;
      --ic-sub-size: 7px;
      --ic-gap: 12px;
    }
  }
</style>
