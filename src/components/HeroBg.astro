---
type Layer = 1 | 2 | 3;

type Brick = {
  id: number;
  layer: Layer;
  x: number;
  y: number;
  w: number;
  h: number;
  r: number;
  hue: number;
  delay: number;
  drift: number;
  spin: number;
  scale: number;
  opacity: number;
};

type CodeToken = {
  text: string;
  color: string;
};

type Particle = {
  id: number;
  layer: Layer;
  x: number;
  y: number;
  hue: number;
  text: string;
  color: string;
  driftX: number;
  driftY: number;
  spin: number;
  duration: number;
  delay: number;
  scale: number;
  opacity: number;
  size: number;
};

const seeded = (index: number): number => {
  const value = Math.sin(index * 999) * 10000;
  return value - Math.floor(value);
};

const codeRows: CodeToken[][] = [
  [
    { text: "function", color: "rgba(129, 140, 248, 0.95)" },
    { text: "buildNPC()", color: "rgba(248, 250, 252, 0.92)" },
  ],
  [
    { text: "if", color: "rgba(244, 114, 182, 0.95)" },
    { text: "(dreamer.ready)", color: "rgba(248, 250, 252, 0.9)" },
    { text: "launch();", color: "rgba(45, 212, 191, 0.95)" },
  ],
  [
    { text: "return", color: "rgba(168, 85, 247, 0.95)" },
    { text: "skills.map", color: "rgba(248, 250, 252, 0.9)" },
    { text: "(nextStep);", color: "rgba(34, 211, 238, 0.94)" },
  ],
  [
    { text: "createNPC()", color: "rgba(132, 204, 22, 0.95)" },
    { text: "(scene,", color: "rgba(248, 250, 252, 0.9)" },
    { text: "{ rotate: 8 });", color: "rgba(56, 189, 248, 0.95)" },
  ],
  [
    { text: "Tranparency", color: "rgba(244, 114, 182, 0.95)" },
    { text: "{ focus }", color: "rgba(248, 250, 252, 0.9)" },
  ],
  [
    { text: "while", color: "rgba(56, 189, 248, 0.95)" },
    { text: "(learning)", color: "rgba(248, 250, 252, 0.9)" },
    { text: "progress++;", color: "rgba(132, 204, 22, 0.94)" },
  ],
  [
    { text: "const", color: "rgba(129, 140, 248, 0.95)" },
    { text: "glow", color: "rgba(248, 250, 252, 0.9)" },
    { text: "=", color: "rgba(148, 163, 184, 0.9)" },
    { text: "`hsl(${hue})`;", color: "rgba(45, 212, 191, 0.94)" },
  ],
  [
    { text: "function", color: "rgba(244, 114, 182, 0.95)" },
    { text: "buildPortfolio()", color: "rgba(248, 250, 252, 0.9)" },
    { text: "{", color: "rgba(148, 163, 184, 0.9)" },
  ],
  [
    { text: "setTimeout", color: "rgba(56, 189, 248, 0.95)" },
    { text: "(()", color: "rgba(248, 250, 252, 0.9)" },
    { text: "=> deploy(), 1200);", color: "rgba(132, 204, 22, 0.95)" },
  ],
  [
    { text: "try", color: "rgba(168, 85, 247, 0.95)" },
    { text: "{ code(); }", color: "rgba(248, 250, 252, 0.9)" },
    { text: "catch", color: "rgba(244, 114, 182, 0.95)" },
  ],
  [
    { text: "const", color: "rgba(129, 140, 248, 0.95)" },
    { text: "mission", color: "rgba(248, 250, 252, 0.9)" },
    { text: "=", color: "rgba(148, 163, 184, 0.9)" },
    { text: "'first web app';", color: "rgba(34, 211, 238, 0.95)" },
  ],
];

const BRICKS_PER_LAYER = 5;
const bricks: Brick[] = Array.from(
  { length: BRICKS_PER_LAYER * 3 },
  (_, index) => {
    const layer: Layer =
      index < BRICKS_PER_LAYER ? 1 : index < BRICKS_PER_LAYER * 2 ? 2 : 3;
    const randomOne = seeded(index + 1);
    const randomTwo = seeded(index + 11);
    const randomThree = seeded(index + 21);
    const randomFour = seeded(index + 31);
    const randomFive = seeded(index + 41);

    const widthBase = layer === 1 ? 168 : layer === 2 ? 136 : 108;
    const widthSpan = layer === 1 ? 132 : layer === 2 ? 104 : 82;
    const heightBase = layer === 1 ? 30 : layer === 2 ? 24 : 20;
    const heightSpan = layer === 1 ? 14 : layer === 2 ? 12 : 10;

    return {
      id: index,
      layer,
      x: 10 + Math.floor(randomOne * 80),
      y: 10 + Math.floor(randomTwo * 80),
      w: widthBase + Math.floor(randomThree * widthSpan),
      h: heightBase + Math.floor(randomFour * heightSpan),
      r: 10 + Math.floor(randomFive * 16),
      hue: Math.floor(randomThree * 360),
      delay: Math.floor(seeded(index + 51) * 6),
      drift: 12 + Math.floor(seeded(index + 61) * 26),
      spin:
        (seeded(index + 71) > 0.5 ? 1 : -1) *
        (5 + Math.floor(seeded(index + 81) * 16)),
      scale: 0.94 + seeded(index + 91) * 0.26,
      opacity: layer === 1 ? 0.95 : layer === 2 ? 0.8 : 0.64,
    };
  },
);

const layerOne = bricks.filter((brick) => brick.layer === 1);
const layerTwo = bricks.filter((brick) => brick.layer === 2);
const layerThree = bricks.filter((brick) => brick.layer === 3);
const MOBILE_VISIBLE_PER_LAYER = 3;

const PARTICLES_PER_LAYER = 5;
const MOBILE_VISIBLE_PARTICLES_PER_LAYER = 2;
const particleRows = codeRows.map((row) => ({
  text: row.map((token) => token.text).join(" "),
  color: row[Math.floor(row.length / 2)]?.color ?? "rgba(186, 230, 253, 0.84)",
}));

const particles: Particle[] = Array.from(
  { length: PARTICLES_PER_LAYER * 3 },
  (_, index) => {
    const layer: Layer =
      index < PARTICLES_PER_LAYER ? 1 : index < PARTICLES_PER_LAYER * 2 ? 2 : 3;
    const randomOne = seeded(index + 201);
    const randomTwo = seeded(index + 211);
    const randomThree = seeded(index + 221);
    const randomFour = seeded(index + 231);
    const randomFive = seeded(index + 241);
    const row = particleRows[index % particleRows.length];

    return {
      id: index,
      layer,
      x: 6 + Math.floor(randomOne * 88),
      y: 8 + Math.floor(randomTwo * 82),
      hue: Math.floor(randomThree * 360),
      text: row.text,
      color: row.color,
      driftX: 10 + Math.floor(randomThree * 22),
      driftY: 8 + Math.floor(randomFour * 18),
      spin: (randomFive > 0.5 ? 1 : -1) * (1 + Math.floor(randomFour * 3)),
      duration: 7.5 + (index % 6) * 1.15,
      delay: seeded(index + 251) * 2.4,
      scale: 0.9 + randomFive * 0.32,
      opacity: layer === 1 ? 0.7 : layer === 2 ? 0.56 : 0.44,
      size: layer === 1 ? 12 : layer === 2 ? 11 : 10,
    };
  },
);

const particleLayerOne = particles.filter((particle) => particle.layer === 1);
const particleLayerTwo = particles.filter((particle) => particle.layer === 2);
const particleLayerThree = particles.filter((particle) => particle.layer === 3);

const codeLineForBrick = (brick: Brick): CodeToken[] =>
  codeRows[brick.id % codeRows.length];
const codeIndentForBrick = (brick: Brick): number =>
  Math.floor(seeded(brick.id + 121) * 28);

const motionPayload = (brick: Brick) => ({
  driftX: Math.round(brick.drift * 0.6),
  driftY: Math.round(brick.drift * 0.95),
  spin: Math.round(brick.spin * 0.75),
  duration: 6 + (brick.id % 5) * 0.85,
  delay: brick.delay * 0.16,
  scale: brick.scale,
});

// ─── ОПТИМІЗАЦІЯ: позиціонування через transform замість left/top ───────────
// translate(-50%,-50%) вже є в рядку — додаємо translate(x%, y%) щоб
// уникнути читання offsetLeft/offsetTop в JS і не провокувати layout.
const brickBaseTransform = (brick: Brick) =>
  `translate(calc(${brick.x}vw - 50%), calc(${brick.y}vh - 50%))`;

const layerOneStyle = (brick: Brick): string =>
  [
    // Позиція через transform — тільки composite, без layout
    "left:0",
    "top:0",
    `width:${brick.w}px`,
    `height:${brick.h}px`,
    `border-radius:${brick.r}px`,
    `opacity:${brick.opacity}`,
    `transform:${brickBaseTransform(brick)}`,
    `background-image:linear-gradient(132deg, rgba(7, 13, 24, 0.92), rgba(15, 23, 42, 0.88) 62%, hsla(${brick.hue + 30}, 96%, 62%, 0.2))`,
    "box-shadow:0 10px 18px rgba(2,6,23,.45)",
    "border:1px solid rgba(125, 211, 252, 0.42)",
    "background-color:rgba(15,23,42,0.55)",
    "overflow:hidden",
    "text-shadow:0 0 4px rgba(56, 189, 248, 0.25)",
    "will-change:transform,opacity",
    "contain:layout paint size",
  ].join(";");

const layerTwoStyle = (brick: Brick): string =>
  [
    "left:0",
    "top:0",
    `width:${brick.w}px`,
    `height:${brick.h}px`,
    `border-radius:${brick.r}px`,
    `opacity:${brick.opacity}`,
    `transform:${brickBaseTransform(brick)}`,
    `background:linear-gradient(136deg, rgba(9, 14, 26, 0.84), rgba(21, 31, 49, 0.78) 58%, hsla(${brick.hue + 14}, 90%, 60%, 0.16))`,
    "box-shadow:0 16px 30px rgba(2, 6, 23, 0.5), 0 0 20px rgba(59, 130, 246, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.16)",
    "border:1px solid rgba(148, 163, 184, 0.36)",
    "backdrop-filter:blur(8px)",
    "overflow:hidden",
    "text-shadow:0 0 10px rgba(125, 211, 252, 0.2)",

    "contain:layout style",
  ].join(";");

const layerThreeStyle = (brick: Brick): string =>
  [
    "left:0",
    "top:0",
    `width:${Math.max(86, brick.w - 20)}px`,
    `height:${Math.max(16, brick.h - 6)}px`,
    `border-radius:${Math.max(8, brick.r - 7)}px`,
    `opacity:${brick.opacity}`,
    `transform:${brickBaseTransform(brick)}`,
    `background:linear-gradient(132deg, rgba(7, 12, 21, 0.74), rgba(17, 24, 39, 0.68) 60%, hsla(${brick.hue + 40}, 88%, 62%, 0.1))`,
    "box-shadow:0 10px 22px rgba(2, 6, 23, 0.42), 0 0 16px rgba(34, 211, 238, 0.05), inset 0 1px 0 rgba(255, 255, 255, 0.14)",
    "border:1px solid rgba(148, 163, 184, 0.24)",
    "backdrop-filter:blur(5px)",
    "overflow:hidden",
    "text-shadow:0 0 8px rgba(125, 211, 252, 0.18)",

    "contain:layout style",
  ].join(";");

const particleStyle = (particle: Particle): string =>
  [
    `left:${particle.x}%`,
    `top:${particle.y}%`,
    `opacity:${particle.opacity}`,
    `font-size:${particle.size}px`,
    "transform:translate(-50%,-50%)",
    `color:${particle.color}`,
    "font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, Liberation Mono, Courier New, monospace",
    "white-space:nowrap",
    "line-height:1",
    `text-shadow:0 0 14px hsla(${particle.hue}, 100%, 72%, 0.28)`,
    "will-change:transform,opacity",
    "contain:layout style",
  ].join(";");
---

<div
  data-hero-bg
  class="absolute inset-0 z-0 overflow-hidden"
  style="perspective:1200px"
>
  <div class="absolute inset-0 bg-paper"></div>
  <div class="absolute inset-0 bg-grid opacity-[0.38]"></div>
  <div
    class="absolute inset-0"
    style="background:radial-gradient(700px 420px at 18% 12%, rgba(34,211,238,0.16), transparent 80%)"
  >
  </div>

  <div
    data-scene
    class="absolute inset-0 will-change-transform"
    style="transform-style:flat"
  >
    <div
      data-layer="1"
      class="absolute inset-0"
      style="transform:translateZ(86px)"
    >
      {
        layerOne.map((brick, layerIndex) => {
          const payload = motionPayload(brick);
          const codeLine = codeLineForBrick(brick);
          const codeIndent = codeIndentForBrick(brick);
          const isMobileVisible = layerIndex < MOBILE_VISIBLE_PER_LAYER;
          return (
            <div
              class={`hb-brick brick-${brick.id} absolute${isMobileVisible ? "" : " hb-mobile-hidden"}`}
              data-brick
              data-mobile-visible={isMobileVisible ? "true" : "false"}
              data-drift-x={payload.driftX}
              data-drift-y={payload.driftY}
              data-spin={payload.spin}
              data-duration={payload.duration}
              data-delay={payload.delay}
              data-scale={payload.scale}
              style={layerOneStyle(brick)}
            >
              <div class="absolute left-0 right-0 top-0 h-[1px] bg-gradient-to-r from-transparent via-white/30 to-transparent" />
              <div
                class="hb-code-line absolute inset-y-0 left-0 right-0 flex items-center gap-[0.34rem] overflow-hidden whitespace-nowrap pr-3 font-mono text-[10px] leading-none tracking-[0.015em] opacity-85"
                style={`padding-left:${10 + codeIndent}px`}
              >
                {codeLine.map((token) => (
                  <span
                    class="hb-token shrink-0"
                    style={`color:${token.color}`}
                  >
                    {token.text}
                  </span>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>

    <div
      data-layer="2"
      class="absolute inset-0"
      style="transform:translateZ(54px)"
    >
      {
        layerTwo.map((brick, layerIndex) => {
          const payload = motionPayload(brick);
          const codeLine = codeLineForBrick(brick);
          const codeIndent = codeIndentForBrick(brick);
          const isMobileVisible = layerIndex < MOBILE_VISIBLE_PER_LAYER;
          return (
            <div
              class={`hb-brick brick-${brick.id} absolute${isMobileVisible ? "" : " hb-mobile-hidden"}`}
              data-brick
              data-mobile-visible={isMobileVisible ? "true" : "false"}
              data-drift-x={payload.driftX}
              data-drift-y={payload.driftY}
              data-spin={payload.spin}
              data-duration={payload.duration}
              data-delay={payload.delay}
              data-scale={payload.scale}
              style={layerTwoStyle(brick)}
            >
              <div class="absolute left-0 right-0 top-0 h-[1px] bg-gradient-to-r from-transparent via-white/20 to-transparent" />
              <div
                class="hb-code-line absolute inset-y-0 left-0 right-0 flex items-center gap-[0.3rem] overflow-hidden whitespace-nowrap pr-3 font-mono text-[9px] leading-none tracking-[0.01em] opacity-80"
                style={`padding-left:${8 + codeIndent}px`}
              >
                {codeLine.map((token) => (
                  <span
                    class="hb-token shrink-0"
                    style={`color:${token.color}`}
                  >
                    {token.text}
                  </span>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>

    <div
      data-layer="3"
      class="absolute inset-0"
      style="transform:translateZ(26px)"
    >
      {
        layerThree.map((brick, layerIndex) => {
          const payload = motionPayload(brick);
          const codeLine = codeLineForBrick(brick);
          const codeIndent = codeIndentForBrick(brick);
          const isMobileVisible = layerIndex < MOBILE_VISIBLE_PER_LAYER;
          return (
            <div
              class={`hb-brick brick-${brick.id} absolute${isMobileVisible ? "" : " hb-mobile-hidden"}`}
              data-brick
              data-mobile-visible={isMobileVisible ? "true" : "false"}
              data-drift-x={payload.driftX}
              data-drift-y={payload.driftY}
              data-spin={payload.spin}
              data-duration={payload.duration}
              data-delay={payload.delay}
              data-scale={payload.scale}
              style={layerThreeStyle(brick)}
            >
              <div class="absolute left-0 right-0 top-0 h-[1px] bg-gradient-to-r from-transparent via-white/18 to-transparent" />
              <div
                class="hb-code-line absolute inset-y-0 left-0 right-0 flex items-center gap-[0.26rem] overflow-hidden whitespace-nowrap pr-2 font-mono text-[8px] leading-none tracking-[0.01em] opacity-75"
                style={`padding-left:${6 + codeIndent}px`}
              >
                {codeLine.map((token) => (
                  <span
                    class="hb-token shrink-0"
                    style={`color:${token.color}`}
                  >
                    {token.text}
                  </span>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</div>

<script>
  import gsap from "gsap";

  const root = document.querySelector("[data-hero-bg]");

  if (root instanceof HTMLElement) {
    type HeroNavigator = Navigator & {
      deviceMemory?: number;
      connection?: {
        saveData?: boolean;
      };
    };

    const scene = root.querySelector("[data-scene]");
    const particleLayerOne = root.querySelector("[data-particle-layer='1']");
    const particleLayerTwo = root.querySelector("[data-particle-layer='2']");
    const particleLayerThree = root.querySelector("[data-particle-layer='3']");

    const media = window.matchMedia("(prefers-reduced-motion: reduce)");
    const mobileBricksMedia = window.matchMedia("(max-width: 1023px)");
    const compactModeMedia = window.matchMedia("(max-width: 1280px)");
    const navigatorData = navigator as HeroNavigator;

    const clamp = (value: number, min: number, max: number): number =>
      Math.min(max, Math.max(min, value));

    const getMode = () => {
      const reduceMotion = media.matches;
      const isMobile = mobileBricksMedia.matches;
      const saveData = Boolean(navigatorData.connection?.saveData);
      const lowMemory =
        typeof navigatorData.deviceMemory === "number"
          ? navigatorData.deviceMemory <= 4
          : false;
      const lowCpu =
        typeof navigator.hardwareConcurrency === "number"
          ? navigator.hardwareConcurrency <= 4
          : false;
      const useLite =
        !reduceMotion && !isMobile && (saveData || lowMemory || lowCpu);

      return { reduceMotion, isMobile, useLite };
    };

    let cachedRect = root.getBoundingClientRect();

    const resizeObserver = new ResizeObserver(() => {
      cachedRect = root.getBoundingClientRect();
    });
    resizeObserver.observe(root);

    const setupAnimations = () => {
      const { reduceMotion, isMobile, useLite } = getMode();
      root.dataset.mode = reduceMotion ? "reduced" : useLite ? "lite" : "full";

      if (isMobile) {
        return () => {};
      }

      const brickSelector = isMobile
        ? "[data-brick][data-mobile-visible='true']"
        : "[data-brick]";
      const particleSelector = isMobile
        ? "[data-particle][data-mobile-visible='true']"
        : "[data-particle]";

      const context = gsap.context(() => {
        gsap.set(brickSelector, {
          force3D: true,
          transformOrigin: "50% 50%",
        });
        if (useLite || reduceMotion) {
          gsap.set(particleSelector, {
            force3D: true,
            transformOrigin: "50% 50%",
          });
        }

        if (reduceMotion) {
          gsap.set(".hb-code-line", { opacity: 0.82, x: 0 });
          gsap.set(particleSelector, {
            opacity: 0.45,
            x: 0,
            y: 0,
            scale: 1,
            rotation: 0,
          });

          return;
        }

        if (!useLite) {
          gsap.to(".hb-code-line", {
            x: 2,
            duration: 2.15,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut",
            stagger: {
              each: 0.05,
              from: "random",
            },
          });
        } else {
          gsap.set(".hb-code-line", { x: 0 });
        }

        if (useLite) {
          if (particleLayerOne instanceof HTMLElement) {
            gsap.to(particleLayerOne, {
              y: -10,
              x: 5,
              duration: 12.6,
              repeat: -1,
              yoyo: true,
              ease: "sine.inOut",
            });
          }

          if (particleLayerTwo instanceof HTMLElement) {
            gsap.to(particleLayerTwo, {
              y: 8,
              x: -4,
              duration: 14.2,
              repeat: -1,
              yoyo: true,
              ease: "sine.inOut",
            });
          }

          if (particleLayerThree instanceof HTMLElement) {
            gsap.to(particleLayerThree, {
              y: -6,
              x: -3,
              duration: 15.6,
              repeat: -1,
              yoyo: true,
              ease: "sine.inOut",
            });
          }

          const particleNodes =
            root.querySelectorAll<HTMLElement>(particleSelector);
          particleNodes.forEach((node) => {
            const driftX = Number(node.getAttribute("data-drift-x") ?? 0);
            const driftY = Number(node.getAttribute("data-drift-y") ?? 0);
            const spin = Number(node.getAttribute("data-spin") ?? 0);
            const scale = Number(node.getAttribute("data-scale") ?? 1);
            const duration = Number(node.getAttribute("data-duration") ?? 7);
            const delay = Number(node.getAttribute("data-delay") ?? 0);

            gsap.to(node, {
              x: `+=${driftX}`,
              y: `-=${driftY}`,
              rotation: `+=${spin}`,
              scale: scale * 1.05,
              duration: duration * 1.2,
              ease: "sine.inOut",
              repeat: -1,
              yoyo: true,
              delay,
            });
          });
        } else {
          const brickNodes = root.querySelectorAll<HTMLElement>(brickSelector);
          brickNodes.forEach((node) => {
            const driftX = Number(node.getAttribute("data-drift-x") ?? 0);
            const driftY = Number(node.getAttribute("data-drift-y") ?? 0);
            const spin = Number(node.getAttribute("data-spin") ?? 0);
            const scale = Number(node.getAttribute("data-scale") ?? 1);
            const duration = Number(node.getAttribute("data-duration") ?? 6);
            const delay = Number(node.getAttribute("data-delay") ?? 0);

            gsap.to(node, {
              keyframes: [
                {
                  x: `+=${driftX}`,
                  y: `-=${driftY}`,
                  rotation: `+=${spin}`,
                  scale: scale * 1.04,
                },
                {
                  x: `-=${Math.round(driftX * 1.4)}`,
                  y: `+=${Math.round(driftY * 1.25)}`,
                  rotation: `-=${Math.round(spin * 1.25)}`,
                  scale: scale * 0.98,
                },
                {
                  x: `+=${Math.round(driftX * 0.4)}`,
                  y: `+=${Math.round(driftY * 0.3)}`,
                  rotation: `+=${Math.round(spin * 0.3)}`,
                  scale,
                },
              ],
              duration,
              ease: "sine.inOut",
              repeat: -1,
              delay,
            });
          });
        }
      }, root);

      const pointerPower = useLite
        ? { x: 8, y: 6, glowX: 90, glowY: 70 }
        : { x: 12, y: 8, glowX: 150, glowY: 110 };

      const sceneRotateX =
        scene instanceof HTMLElement
          ? gsap.quickTo(scene, "rotationX", {
              duration: 0.45,
              ease: "power3.out",
            })
          : null;
      const sceneRotateY =
        scene instanceof HTMLElement
          ? gsap.quickTo(scene, "rotationY", {
              duration: 0.45,
              ease: "power3.out",
            })
          : null;

      let pendingPointerX = 0;
      let pendingPointerY = 0;
      let pointerFrame = 0;

      const flushPointer = () => {
        pointerFrame = 0;

        sceneRotateY?.(
          clamp(
            pendingPointerX * pointerPower.x,
            -pointerPower.x,
            pointerPower.x,
          ),
        );
        sceneRotateX?.(
          clamp(
            pendingPointerY * -pointerPower.y,
            -pointerPower.y,
            pointerPower.y,
          ),
        );

        glowX?.(pendingPointerX * pointerPower.glowX);
        glowY?.(pendingPointerY * pointerPower.glowY);
        glowOpacity?.(useLite ? 0.68 : 0.78);
      };

      const onPointerMove = (event: PointerEvent) => {
        if (reduceMotion) return;

        pendingPointerX =
          (event.clientX - cachedRect.left) / cachedRect.width - 0.5;
        pendingPointerY =
          (event.clientY - cachedRect.top) / cachedRect.height - 0.5;

        if (pointerFrame === 0) {
          pointerFrame = window.requestAnimationFrame(flushPointer);
        }
      };

      const onPointerLeave = () => {
        if (pointerFrame) {
          window.cancelAnimationFrame(pointerFrame);
          pointerFrame = 0;
        }

        sceneRotateY?.(0);
        sceneRotateX?.(0);

      };

      root.addEventListener("pointermove", onPointerMove, { passive: true });
      root.addEventListener("pointerleave", onPointerLeave);

      return () => {
        if (pointerFrame) {
          window.cancelAnimationFrame(pointerFrame);
        }
        root.removeEventListener("pointermove", onPointerMove);
        root.removeEventListener("pointerleave", onPointerLeave);
        context.revert();
      };
    };

    let cleanupAnimations = setupAnimations();

    const onMediaChange = () => {
      cleanupAnimations();
      cleanupAnimations = setupAnimations();
    };

    media.addEventListener?.("change", onMediaChange);
    mobileBricksMedia.addEventListener?.("change", onMediaChange);
    compactModeMedia.addEventListener?.("change", onMediaChange);

    window.addEventListener(
      "beforeunload",
      () => {
        cleanupAnimations();
        resizeObserver.disconnect();
        media.removeEventListener?.("change", onMediaChange);
        mobileBricksMedia.removeEventListener?.("change", onMediaChange);
        compactModeMedia.removeEventListener?.("change", onMediaChange);
      },
      { once: true },
    );
  }
</script>

